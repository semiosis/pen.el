#!/bin/bash
export TTY
export DISPLAY
# ( hs "$(basename -- "$0")" "$@" "#" "<==" "$(ps -o comm= $PPID)" 0</dev/null ) &>/dev/null

. $SCRIPTS/lib/stdin_exists

test -f "/usr/local/bin/vim" && : "${bin:="/usr/local/bin/vim"}"
test -f "/usr/bin/vim" && : "${bin:="/usr/bin/vim"}"

is_emacs_shell() {
    [[ $INSIDE_EMACS == *,comint ]] || [[ $INSIDE_EMACS == *,eshell ]];
}

is_tty() {
    # If stout is a tty
    [ -t 1 ] && ! test "$TERM" = "dumb" && ! is_emacs_shell;
}

is_stdout_pipe() {
    # If stout is a pipe
    [[ -p /dev/stdout ]]
}

if test "$BLACK_AND_WHITE" = y || pen-rc-test -f black_and_white; then
    # Do this especially if INSIDE_EMACS
    export TERM=screen-2color
    extra_commands+="|call BWSyntax()"
fi

run() {
    if is_tty; then
        "$bin" "$@"
    elif is_stdout_pipe; then
        CMD="$(cmd "$@")"
        : ${CMD:="$(cmd "$@")"}
        # cmd "unbuffer $bin -c $(cmd-nice-posix "$extra_commands") $CMD -c \"wq! /tmp/vim-stdout.txt\"" | tv &>/dev/null
        eval "unbuffer $bin -c $(cmd-nice-posix "$extra_commands") $CMD -c \"wq! /tmp/vim-stdout.txt\"" &>/dev/null
        cat /tmp/vim-stdout.txt
    else
        echo "[[e:vim]] No tty. Opening in a tmux popup." 1>&2
        tpop vim "$@"
    fi
}

# Do this to remove the annoying message from vim
if stdin_exists; then
    IFS= read -rd '' contents < <(cat);typeset -p contents &>/dev/null
    if test -n "$contents"; then
        printf -- "%s" "$contents" | run "$@"
    fi
else
    run "$@"
fi
